	ctx := WailsContext
	if ctx == nil {
		ctx = context.TODO()
	}
	if err := f.internal.SaveThemeConfig(ctx, config); err != nil {
		return err
	}

	// Trigger render
	if f.renderer != nil {
		go func() {
			if err := f.renderer.RenderAll(); err != nil {
