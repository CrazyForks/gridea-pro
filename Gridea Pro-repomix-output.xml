                    </template>

                    <PaginationItem>
                        <PaginationNext
:class="{ 'pointer-events-none opacity-50': currentPage === totalPages }"
                            @click="currentPage < totalPages && handlePageChanged(currentPage + 1)" />
                    </PaginationItem>
